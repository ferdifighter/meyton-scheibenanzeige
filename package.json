{
  "name": "scheibenanzeige-desktop",
  "version": "1.2.0",
  "private": true,
  "description": "Scheibenanzeige – Desktop (Electron + AppImage)",
  "author": "Schützenverein Greif e.V. Blumenthal",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferdifighter/meyton-scheibenanzeige.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client && npm install",
    "build:client": "npm run build --prefix client",
    "electron:dev": "electron .",
    "electron:pack": "npm run build:client && electron-builder --linux AppImage",
    "electron:pack:dir": "npm run build:client && electron-builder --linux --dir",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "publish": null,
    "appId": "de.greif.blumenthal.scheibenanzeige",
    "productName": "Scheibenanzeige",
    "copyright": "Copyright © Schützenverein Greif e.V. Blumenthal",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": ["**/*", "!**/.env"]
      },
      {
        "from": "client/dist",
        "to": "client/dist"
      }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "maintainer": "Schützenverein Greif e.V. Blumenthal"
    }
  }
}
