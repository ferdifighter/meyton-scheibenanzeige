DB_HOST=192.168.10.200
DB_PORT=3306
DB_USER=meyton
DB_PASSWORD=
DB_NAME=SSMDB2
PORT=3001

# Optional: Pfad zu db-settings.json (UI „Einstellungen“); sonst server/data/db-settings.json
# SCHEIBENANZEIGE_SETTINGS_PATH=/pfad/zu/db-settings.json
#
# Optional: Pfad zu ui-settings.json (Scheibenanzeige: Seitenwechsel); sonst server/data/ui-settings.json
# SCHEIBENANZEIGE_UI_SETTINGS_PATH=/pfad/zu/ui-settings.json
#
# Optional: Nur nötig für API-Hinweis „Speicherort“; setzt die Desktop-App (AppImage) automatisch
# SCHEIBENANZEIGE_USER_DATA_DIR=/pfad/zum/Benutzerverzeichnis
#
# Optional: Max. Scheiben für GET /api/board (Schutz vor sehr großen Abfragen), bis 50000
# BOARD_MAX_LIMIT=5000

# --- Anzeige-Filter (Meyton SSMDB2 hat kein „Stand eingeschaltet“) ---
# Nur diese Stände (Komma), z. B. wenn Stand 7 ausgeschaltet ist:
# ACTIVE_STAND_NUMBERS=1,2,3,4,5,6,8
#
# Standard: nur Scheiben von HEUTE (Zeitstempel). Für Tests alle Tage:
# SCHEIBEN_ALL_DATES=1
#
# Nur eine Scheibe pro Stand (aktuellste Zuordnung wie Live-Anzeige):
# LATEST_PER_STAND=false
#
# Welche Zeile pro Stand gilt als „aktuell“ (ROW_NUMBER ORDER BY):
# scheibenid = neueste DB-Zeile (Standard, sinnvoll wenn fertige Sessions den neueren Zeitstempel haben)
# zeitstempel = nach letztem Schuss (altes Verhalten)
# LATEST_RANK_BY=scheibenid
#
# Optional nur Veranstaltung (Teilstring Starterliste):
# STARTERLISTE_FILTER=Kreismeisterschaft
